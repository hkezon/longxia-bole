# ==========================================
# Lobster Sentinel (龙虾) 核心环境配置文件模板
# ==========================================

# 1. OKX Onchain OS / API 物理隔离配置 (请勿将真实 Key 提交至云端)
OKX_API_KEY=your_api_key_here
OKX_SECRET_KEY=your_secret_key_here
OKX_PASSPHRASE=your_passphrase_here

# 2. Telegram 只读审计与硬拦截推送端点
TELEGRAM_BOT_TOKEN=your_tg_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# 3. Guard 状态机刚性风控参数 (支持本地覆盖)
MAX_DRAWDOWN_PCT=0.05          # 最大允许回撤 (5%)
FOMO_INDEX_THRESHOLD=80        # 市场极端波动/追高情绪熔断阈值
SLEEP_MODE_ENABLED=true        # 是否开启睡眠期防爆仓接管
